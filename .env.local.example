# ── Supabase (https://supabase.com → Project Settings → API) ──────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Admin panel passcode (change this!) ───────────────────────────────
NEXT_PUBLIC_ADMIN_PASSCODE=hustlehard2026

# ── Microsoft Clarity — free heatmaps & recordings (clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=

# ── Tawk.to — free live chat (tawk.to → Chat Widget → embed URL IDs)
#    https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# ── Google Search Console verification meta tag content value ─────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Stripe payments (stripe.com → Developers → API keys) ──────────────
#    Use sk_test_... first to test, then swap to sk_live_...
#    Set NEXT_PUBLIC_STRIPE_ENABLED=1 to show Pay Now buttons site-wide.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_ENABLED=
